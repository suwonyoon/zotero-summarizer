{
  "name": "zotero-gpt",
  "type": "module",
  "version": "0.1.0",
  "description": "AI-powered PDF summarization for Zotero using OpenAI GPT",
  "config": {
    "addonName": "ZoteroGPT",
    "addonID": "zotero-gpt@suwonyoon.dev",
    "addonRef": "zoterogpt",
    "addonInstance": "ZoteroGPT",
    "prefsPrefix": "extensions.zotero.zoterogpt"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/suwonyoon/zotero-gpt.git"
  },
  "author": "Suwon Yoon <suwon.yoon@postech.ac.kr>",
  "bugs": {
    "url": "https://github.com/suwonyoon/zotero-gpt/issues"
  },
  "homepage": "https://github.com/suwonyoon/zotero-gpt#readme",
  "license": "AGPL-3.0",
  "keywords": [
    "zotero",
    "zotero-plugin",
    "ai",
    "gpt",
    "openai",
    "pdf",
    "summarization",
    "academic",
    "research",
    "machine-learning",
    "natural-language-processing",
    "zotero-7"
  ],
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "zotero-plugin-toolkit": "^5.1.0-beta.4"
  },
  "devDependencies": {
    "@types/chai": "^5.2.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.2.0",
    "@zotero-plugin/eslint-config": "^0.6.7",
    "chai": "^5.2.1",
    "eslint": "^9.32.0",
    "mocha": "^11.7.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "zotero-plugin-scaffold": "^0.8.0",
    "zotero-types": "^4.1.0-beta.3"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
